# Application
APP_NAME=ResilienceNet
APP_VERSION=1.0.0
DEBUG=true

# Database (SQLite default, uncomment PostgreSQL for production)
DATABASE_URL=sqlite:///./resiliencenet.db
# DATABASE_URL=postgresql://user:password@localhost:5432/resiliencenet

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Geo Settings
DUPLICATE_RADIUS_METERS=500.0
HIGH_ACTIVITY_THRESHOLD=3
HIGH_ACTIVITY_WINDOW_MINUTES=30
AUTO_EXPIRY_HOURS=24
