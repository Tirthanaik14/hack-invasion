# Environment variables for ResilienceNet Backend
# Copy this to .env and fill in your values

# Application
APP_NAME=ResilienceNet
APP_VERSION=1.0.0
DEBUG=True

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./resiliencenet.db
# DATABASE_URL=postgresql://user:password@localhost:5432/resiliencenet

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=resiliencenet-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Credentials - CHANGE THESE IN PRODUCTION!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Incident Settings
DUPLICATE_RADIUS_METERS=500.0
HIGH_ACTIVITY_THRESHOLD=3
HIGH_ACTIVITY_WINDOW_MINUTES=30
AUTO_EXPIRY_HOURS=24
